{%
  set classes = [
    'container px-6 2xl:px-0 py-20 lg:py-32 px-6 2xl:px-0  mx-auto max-w-[1400px]',
    'paragraph',
    'paragraph--type--' ~ paragraph.bundle|clean_class,
    view_mode ? 'paragraph--view-mode--' ~ view_mode|clean_class,
    not paragraph.isPublished() ? 'paragraph--unpublished'
  ]
%}
{% block paragraph %}
  <section
    {{ attributes
      .addClass(classes)
      .addClass('relative overflow-hidden', 'auto-animate')
      .setAttribute('data-animate', 'fade-up')
    }}
  >
    {% block content %}
      <div class="w-16 h-1 bg-amber-600 mb-6"></div>
      <h3 class="font-serif text-4xl lg:text-5xl tracking-tight mb-6 font-semibold">
        {{ content.field_section_title[0]['#context']['value'] }}
      </h3>
      <div class="text-content text-content-editor mt-10">
        {{ content.field_body }}
      </div>
    {% endblock %}
  </section>
{% endblock paragraph %}
