{#
/**
 * Template ajustado para evitar renderização de campos vazios e
 * garantir a integridade do layout Grid.
 */
#}
{%
  set classes = [
    'container-fluid mx-auto',
    'paragraph',
    'paragraph--type--' ~ paragraph.bundle|clean_class,
    view_mode ? 'paragraph--view-mode--' ~ view_mode|clean_class,
    not paragraph.isPublished() ? 'paragraph--unpublished',
    'py-20 lg:py-32 bg-stone-50 relative'
  ]
%}

{% block paragraph %}
  {# Só renderiza o container principal se houver algum conteúdo nos campos #}
  {% if content.field_section_title|render or content.field_body|render %}
    <section
      {{ attributes
        .addClass(classes)
        .addClass('relative overflow-hidden', 'auto-animate')
        .setAttribute('data-animate', 'fade-up')
      }}
    >
      <div class="container mx-auto px-6 2xl:px-0 max-w-[1400px]">
        {% block content %}
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-start">
            
            {# Coluna do Título (1/3) #}
            {% if content.field_section_title|render %}
              <div class="max-w-[350px]">
                <div class="w-16 h-1 bg-amber-600 mb-6"></div>
                <h3 class="font-serif text-4xl lg:text-5xl tracking-tight mb-6 font-semibold">
                  {{ content.field_section_title[0]['#context']['value'] }}
                </h3>
              </div>
            {% else %}
              {# Div vazia para manter o grid se apenas o corpo existir, 
                ou você pode remover o grid se preferir. #}
              <div class="hidden md:block"></div>
            {% endif %}

            {# Coluna do Conteúdo (2/3) #}
            {% if content.field_body|render %}
              <div class="md:col-span-2 animate-fade-left">
                <div class="text-base leading-relaxed">
                  {# Removido o <p> fixo pois o CKEditor geralmente já envia o conteúdo dentro de <p> #}
                  {{ content.field_body }}
                </div>
              </div>
            {% endif %}

          </div>
        {% endblock %}
      </div>
    </section>
  {% endif %}
{% endblock paragraph %}