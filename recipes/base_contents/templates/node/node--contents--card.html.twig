<div class="group bg-white border border-neutral-200 hover:border-neutral-900 transition-all overflow-hidden h-full">
  <div class="relative aspect-[16/9] overflow-hidden bg-neutral-100">
    {% if node.field_thumbnail_image.entity or node.field_featured_image.entity %}
  
      {# Definindo a variável usando a sintaxe correta ?: #}
      {% set media_entity = node.field_thumbnail_image.entity ?: node.field_featured_image.entity %}
      
      {# Pegando a URL de forma segura #}
      {% set image_url = file_url(media_entity.field_media_image.entity.uri.value) %}

      <a href="{{ path('entity.node.canonical', {'node': node.id}) }}" class="" data-discover="true">
        <img 
          src="{{ image_url }}" 
          alt="{{ node.label }}" 
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        >
      </a>
    {% endif %}
    {% if content.field_content_category[0] is not empty %}
      <div class="absolute top-4 left-4 px-3 py-1 bg-white/90 backdrop-blur-sm text-xs tracking-widest uppercase">
        <a href="{{ path('entity.taxonomy_term.canonical', {'taxonomy_term': node.field_category.entity.id}) }}" class="text-emerald-700 hover:text-emerald-900 transition-colors"> 
          {{ content.field_content_category }}
        </a>
      </div>
    {% endif %}
  </div>
  <div class="p-8 space-y-4" >
    <a href="{{ path('entity.node.canonical', {'node': node.id}) }}" class="" data-discover="true">
      <h3 class="font-serif text-2xl lg:text-3xl tracking-tight leading-tight group-hover:text-neutral-600 transition-colors font-medium">
        {{ label }}
      </h3>
    </a>
    <p class="text-neutral-600 leading-relaxed line-clamp-2">
      {{ node.body.summary ?: node.body.value|striptags|slice(0, 200) }}
    </p>

    {% if content.field_tags %}
      <div class="flex flex-wrap gap-2 pt-2">
        {% for tag_item in node.field_tags %}
          {% set tag = tag_item.entity %}
          {% if tag %}
            <a href="{{ path('entity.taxonomy_term.canonical', {'taxonomy_term': tag.id}) }}" 
              class="inline-flex items-center gap-1 px-2 py-1 text-[10px] uppercase tracking-wider border border-neutral-300 hover:border-emerald-700 hover:bg-emerald-50 transition-colors text-neutral-600 hover:text-emerald-700">
              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l8.704 8.704a2.426 2.426 0 0 0 3.42 0l6.58-6.58a2.426 2.426 0 0 0 0-3.42z"></path>
                <circle cx="7.5" cy="7.5" r=".5" fill="currentColor"></circle>
              </svg>
              {{ tag.label }}
            </a>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
    <div class="flex items-center justify-between pt-4 border-t border-neutral-200" >
      {# Autor #}
      
      <div class="flex items-center gap-3" >
        {% if node.field_author.entity %}
          {% set author = node.field_author.entity %}
          {% if author.field_team_image %}
            {% set author_image = author.field_team_image.entity.field_media_image.entity.uri.value %}
            <div class="w-10 h-10 rounded-full overflow-hidden bg-neutral-200" >
              <img src="{{ file_url(author_image) }}" alt="{{ author.label }}" class="w-full h-full object-cover" >
            </div>
          {% endif %}
          <div >
            <div class="text-sm" >
              {{ author.field_prefix.value }} {{ author.label }}
            </div>
            <div class="text-xs text-neutral-500">{{ node.created.value|format_date('custom', 'd M Y', null, 'pt-br') }}</div>
          </div>
        {% endif %}
      </div>
      <div class="flex items-center gap-2 text-sm text-neutral-500" >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-clock" >
          <circle cx="12" cy="12" r="10"></circle>
          <polyline points="12 6 12 12 16 14"></polyline>
        </svg>
        {{ reading_time }} min de leitura
      </div>
    </div>
    <div class="flex items-center gap-2 text-emerald-700 text-sm tracking-wide" >
      <a href="{{ path('entity.node.canonical', {'node': node.id}) }}" class="flex" data-discover="true">
        {{ 'Leia Mais'|t }}
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-right">
          <path d="m9 18 6-6-6-6"></path>
        </svg>
      </a>
    </div>
  </div>
</div>