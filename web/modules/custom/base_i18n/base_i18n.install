<?php

function base_i18n_install() {
  $languages = \Drupal::state()->get('base_i18n.languages', []);

  foreach ($languages as $langcode => $label) {
    if (!\Drupal::service('language_manager')->getLanguage($langcode)) {
      $language = \Drupal\language\Entity\ConfigurableLanguage::create([
        'id' => $langcode,
        'label' => $label,
      ]);
      $language->save();
    }
  }
}