<ul class="flex flex-col md:flex-row gap-0 lg:gap-4 items-start md:items-center md:justify-end">
	{% for item in menu %}
		<li class="relative group {% if item.below %}has-dropdown{% endif %}">
			<a href="{{ item.url }}" class="text-sm tracking-wide hover:text-neutral-600 px-2 transition-colors {{ item.in_active_trail ? 'text-gray-900' : 'text-gray-600' }}">
				{{ item.title }}
			</a>

			{% if item.below %}
				<ul class="dropdown hidden relative lg:absolute left-0 mt-4 pb-2 bg-white lg:shadow-md min-w-[200px] z-50">
					{% for subitem in item.below %}
						<li>
							<a href="{{ subitem.url }}" class="block px-6 py-4 text-sm hover:bg-gray-100">
								{{ subitem.title }}
							</a>
						</li>
					{% endfor %}
				</ul>
			{% endif %}
		</li>
	{% endfor %}
</ul>
