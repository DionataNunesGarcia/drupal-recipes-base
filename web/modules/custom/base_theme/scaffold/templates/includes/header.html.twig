<header class="header-main bg-white shadow-md border-gray-800 sticky top-0 z-50">
	<div
		class="container mx-auto px-6 2xl:px-0 py-4 flex items-center justify-between max-w-[1400px]">

		{# Logo #}
		<div class="flex items-center gap-4">
			<div class="text-xl font-bold">
				<a href="{{ path('<front>') }}" class="text-white hover:text-gray-300">
					<img src="{{ site_logo }}" alt="{{ site_name }} logo" class="logo">
				</a>
			</div>
		</div>

		{# Hamburger Mobile no canto direito #}
		<button id="hamburger" class="md:hidden ml-auto flex flex-col justify-center items-center w-8 h-8 gap-1">
			<span class="block w-6 h-0.5 bg-gray-800 transition-transform duration-300"></span>
			<span class="block w-6 h-0.5 bg-gray-800 transition-opacity duration-300"></span>
			<span class="block w-6 h-0.5 bg-gray-800 transition-transform duration-300"></span>
		</button>

		{# Menu + CTA #}
		<div
			id="menu" class="hidden absolute top-full left-0 w-full bg-white flex flex-col md:relative md:flex md:flex-row md:items-center md:gap-6 px-6 lg:px-0 py-0 shadow-lg md:shadow-none">

			{# Menu principal #}
			<nav class="flex flex-col md:flex-row md:items-center md:gap-4 w-full">
				<div class="flex flex-col md:flex-row md:gap-2 items-start md:items-center lg:justify-end w-full">
					{% include '@front_theme/includes/main-menu.html.twig' with {'menu': menu_main} %}
				</div>
			</nav>

			{# CTAs #}
			<div class="flex flex-col md:flex-row gap-4 mt-4 md:mt-0 w-full md:w-auto">
				{% include '@front_theme/includes/menus.html.twig' with {'menu': menu_cta} %}
			</div>
		</div>
	</div>
</header>
