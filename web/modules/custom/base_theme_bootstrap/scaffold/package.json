{
  "name": "front_theme",
  "version": "1.0.0",
  "description": "Drupal theme scaffold with Bootstrap 5",
  "scripts": {
    "dev": "npm-run-all --parallel watch:*",
    "watch": "npm-run-all --parallel watch:*",
    "watch:scss": "sass --no-source-map --load-path=node_modules --quiet-deps --watch src/scss/style.scss dist/css/style.css",
    "watch:js": "esbuild src/js/main.js --bundle --outfile=dist/js/main.js --watch",
    "build": "npm-run-all build:*",
    "build:scss": "sass --no-source-map --load-path=node_modules --quiet-deps --style=compressed src/scss/style.scss dist/css/style.css",
    "build:js": "esbuild src/js/main.js --bundle --minify --outfile=dist/js/main.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "esbuild": "^0.20.0",
    "npm-run-all": "^4.1.5",
    "sass": "^1.70.0"
  },
  "dependencies": {
    "bootstrap": "^5.3.3",
    "bootstrap-icons": "^1.11.3",
    "@popperjs/core": "^2.11.8",
    "gsap": "^3.12.5",
    "glightbox": "^3.3.0",
    "aos": "^2.3.4",
    "swiper": "^11.1.0"
  }
}
