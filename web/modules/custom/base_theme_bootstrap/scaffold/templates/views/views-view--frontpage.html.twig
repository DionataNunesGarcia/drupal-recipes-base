{%
  set classes = [
    'container',
    'py-5',
    'view',
    'view-' ~ id|clean_class,
    'view-id-' ~ id,
    'view-display-id-' ~ display_id,
    dom_id ? 'js-view-dom-id-' ~ dom_id,
  ]
%}

<div{{ attributes.addClass(classes) }}>
  
  {{ title_prefix }}

  {% if title %}
    <div class="mb-4">
      {{ title }}
    </div>
  {% endif %}

  {{ title_suffix }}

  {% if header %}
    <div class="view-header mb-4">
      {{ header }}
    </div>
  {% endif %}

  {% if exposed %}
    <div class="view-filters mb-4">
      {{ exposed }}
    </div>
  {% endif %}

  {% if attachment_before %}
    <div class="attachment attachment-before mb-4">
      {{ attachment_before }}
    </div>
  {% endif %}

  {% if rows %}
    <div class="view-content row g-4">
      {{ rows }}
    </div>
  {% elseif empty %}
    <div class="alert alert-light">
      {% include '@olivero/includes/get-started.html.twig' %}
    </div>
  {% endif %}

  {% if pager %}
    <div class="mt-4">
      {{ pager }}
    </div>
  {% endif %}

  {% if attachment_after %}
    <div class="attachment attachment-after mt-4">
      {{ attachment_after }}
    </div>
  {% endif %}

  {% if more %}
    <div class="mt-4 text-center">
      {{ more }}
    </div>
  {% endif %}

  {% if footer %}
    <div class="view-footer mt-5">
      {{ footer }}
    </div>
  {% endif %}

</div>