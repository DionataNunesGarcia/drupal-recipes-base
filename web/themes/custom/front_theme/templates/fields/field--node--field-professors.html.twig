{% for item in items %}
  {% set node = item.content['#node'] %}

  <a class="flex justify-start gap-4 w-full mb-4 xl:mb-6" href="{{ path('entity.node.canonical', {'node': node.id}) }}" data-discover="true">
    <div class="w-16 h-16 rounded-full overflow-hidden bg-neutral-200 flex-shrink-0">
      <img 
        src="{{ file_url(node.field_team_image.entity.field_media_image.entity.uri.value)}}" 
        alt="{{ node.title.value }}" 
        class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all"
      >
    </div>
    <div>
      <div class="font-serif text-xl tracking-tight">
        {{ node.field_prefix.value }} {{ node.title.value }}
      </div>
      <div class="text-sm text-neutral-600">
        {% if node.field_team_role %}
          {% for role in node.field_team_role %}
            {{ role.entity.label }}
            {% if not loop.last %}
              <span>|</span>
            {% endif %}
          {% endfor %}
        {% endif %}
      </div>
    </div>
  </a>
{% endfor %}