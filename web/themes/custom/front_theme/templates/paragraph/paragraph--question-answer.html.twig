<div class="bg-white border border-neutral-200 overflow-hidden hover:border-emerald-700 transition-colors mb-4 animate-fade-up">

  <div
    class="w-full text-left px-4 py-6 font-medium flex justify-between items-center accordion-trigger"
  >
    <h4>
      {{ content.field_question[0]["#context"]['value'] }}
    </h4>
    <span class="accordion-icon">+</span>
  </div>

  <div class="accordion-content text-content-editor hidden px-6 lg:px-8 pb-6 lg:pb-8 text-neutral-600 leading-relaxed border-t border-emerald-700/20 pt-4">
    {{ content.field_answer[0]['#text']|raw }}
  </div>
</div>
