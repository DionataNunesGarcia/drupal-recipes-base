
{%
  set classes = [
    'content-type',
    'content--type--' ~ node.bundle|clean_class,
    not node.isPublished() ? 'content--unpublished',
    'min-h-screen bg-white'
  ]
%}

<div{{ attributes.addClass(classes) }}>
  <section class="relative pt-32 pb-20 px-6 lg:px-12 overflow-hidden">
    <div class="absolute inset-0 featured-image">
      {{ content.field_featured_image }}
      <div class="absolute inset-0 bg-gradient-to-b from-black/60 to-black/80"></div>
    </div>
    <div class="max-w-4xl mx-auto relative z-10 text-white">
      <a 
				class="inline-flex items-center gap-2 mb-8 text-sm tracking-wide hover:opacity-70 transition-opacity" 
				href="{{ content.field_category[0]['#url'].toString() }}" 
				data-discover="true"
			>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-left">
          <path d="m12 19-7-7 7-7"></path>
          <path d="M19 12H5"></path>
        </svg>
       	{{ 'Voltar aos '}}{{ content.field_category[0]['#title'] }}
      </a>
      <div class="space-y-6">
        <div class="inline-block px-4 py-2 bg-white/10 backdrop-blur-sm border border-white/20 text-sm tracking-widest uppercase">
					{{ content.field_content_category }}
				</div>
				{{ title_prefix }}
					<h1 class="font-serif text-4xl lg:text-6xl leading-[1.1] tracking-tight">
						{{ label }}
					</h1>
				{{ title_suffix }}
        <p class="text-xl text-white/90 leading-relaxed">
					{{ node.body.summary ?: node.body.value|striptags|slice(0, 200) }}
				</p>
        <div class="flex flex-wrap items-center gap-6 pt-6 border-t border-white/20">
          {% if node.field_author.entity %}
						{% set author = node.field_author.entity %}
						<div class="flex items-center gap-3 max-w-[350px]">
							{% if author.field_team_image %}
								{% set author_image = author.field_team_image.entity.field_media_image.entity.uri.value %}
								<div class="w-12 h-12 rounded-full overflow-hidden bg-neutral-200">
									<img src="{{ file_url(author_image) }}" alt="{{ author.label }}" class="w-full h-full object-cover">
								</div>
							{% endif %}
							
							<div>
								<div class="tracking-wide">
									<a 
										href="{{ path('entity.node.canonical', {'node': author.id}) }}"
										data-discover="true"
									>
										{{ author.field_prefix.value }} {{ author.label }}
									</a>
								</div>
								<div class="text-sm text-white/60">
									{% if author.field_team_role %}
										{% for item in author.field_team_role %}
											<span>{{ item.entity.label }}</span>
											{% if not loop.last %}
												|
											{% endif %}
										{% endfor %}
									{% endif %}
								</div>
							</div>
						</div>
					{% endif %}
          <div class="flex items-center gap-4 text-sm text-white/80">
            <span class="flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-clock">
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
              {{ reading_time }} {{ 'minutos de leitura'|t }}
            </span>
            <span>•</span><span>{{ node.created.value|format_date('custom', 'd M Y', null, 'pt-br') }}</span>
          </div>
        </div>
      </div>
    </div>
  </section>
  <article class="py-20 px-6 lg:px-12">
    <div class="max-w-3xl mx-auto">
      <div class="prose prose-lg max-w-none">
        {{ content.body }}
      </div>
			{% if content.field_tags %}
				<div class="mt-16 pt-8 border-t border-neutral-200">
					<div class="flex items-center gap-3 flex-wrap">
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-tag text-neutral-400">
							<path d="M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l8.704 8.704a2.426 2.426 0 0 0 3.42 0l6.58-6.58a2.426 2.426 0 0 0 0-3.42z"></path>
							<circle cx="7.5" cy="7.5" r=".5" fill="currentColor"></circle>
						</svg>
						{% for tag_item in node.field_tags %}
							{% set tag = tag_item.entity %}
							{% if tag %}
								<a href="{{ path('entity.taxonomy_term.canonical', {'taxonomy_term': tag.id}) }}"
									class="px-3 py-1 text-sm border border-neutral-300 hover:border-neutral-900 transition-colors cursor-pointer">
									{{ tag.label }}
								</a>
							{% endif %}
						{% endfor %}
					</div>
				</div>
			{% endif %}

      {% include '@front_theme/includes/share-buttons.html.twig' with {
				url: url('<current>', { absolute: true }),
				title: node.label
			} %}
			{% if author %}
				<a 
					class="block mt-12 p-8 border-2 border-neutral-900 hover:bg-neutral-900 hover:text-white transition-colors group" 
					href="{{ path('entity.node.canonical', {'node': author.id}) }}"
					data-discover="true"
				>
					<div class="flex items-center gap-6">
						<div class="w-20 h-20 rounded-full overflow-hidden bg-neutral-200 flex-shrink-0">
							<img src="{{ file_url(author_image) }}" alt="{{ author.label }}" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all">
						</div>
						<div>
							<div class="flex items-center gap-2 mb-2">
								<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-user">
									<path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
									<circle cx="12" cy="7" r="4"></circle>
								</svg>
								<span class="text-sm tracking-wide uppercase opacity-70">
									{{ 'Sobre o autor'|t }}
								</span>
							</div>
							<div class="font-serif text-2xl tracking-tight mb-1">
								{{ author.field_prefix.value }} {{ author.label }}
							</div>
							<div class="text-sm opacity-80">
								{% if author.field_team_role %}
									{% for item in author.field_team_role %}
										<span>{{ item.entity.label }}</span>
										{% if not loop.last %}
											|
										{% endif %}
									{% endfor %}
								{% endif %}
							</div>
						</div>
					</div>
				</a>
			{% endif %}
    </div>
  </article>
  {{ content.field_sections }}
  {{ related_content }}
  <section class="py-20 lg:py-32 px-6 lg:px-12 bg-stone-50 relative">
    <div class="absolute inset-0 pointer-events-none opacity-20">
      <svg class="w-full h-full text-neutral-900" viewBox="0 0 200 200" preserveAspectRatio="xMidYMid slice">
        <defs>
          <pattern id="circlePattern" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
            <circle cx="20" cy="20" r="8" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.05"></circle>
            <circle cx="0" cy="0" r="8" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.05"></circle>
            <circle cx="40" cy="40" r="8" fill="none" stroke="currentColor" stroke-width="0.5" opacity="0.05"></circle>
          </pattern>
        </defs>
        <rect width="200" height="200" fill="url(#circlePattern)"></rect>
      </svg>
    </div>
    <div class="absolute bottom-0 right-0 w-32 h-32 opacity-10 pointer-events-none">
      <svg viewBox="0 0 100 100" class="text-emerald-800">
        <path d="M0,0 L50,0 L25,43.3 Z" fill="currentColor"></path>
        <path d="M50,0 L100,0 L75,43.3 Z" fill="currentColor" opacity="0.6"></path>
        <path d="M25,43.3 L75,43.3 L50,86.6 Z" fill="currentColor" opacity="0.4"></path>
      </svg>
    </div>
    <div class="max-w-[1400px] mx-auto relative z-10">
      <div class="text-center mb-12">
        <h2 class="font-serif text-3xl lg:text-4xl tracking-tight mb-4">
					{{'Continue lendo'}}
				</h2>
        <p class="text-lg text-neutral-600">
					{{ 'Mais informações sobre saúde mental na população negra e prática psicanalítica.'|t }}
				</p>
      </div>
      <div class="flex justify-center">
				<a class="px-8 py-4 bg-emerald-700 text-white tracking-wide hover:opacity-90 transition-opacity" href="/#articles" data-discover="true">
					{{ 'Ver todos os ' }} {{ content.field_category[0]['#title'] }}
				</a>
			</div>
    </div>
  </section>

</div>